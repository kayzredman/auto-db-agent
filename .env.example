# Internal Metrics Database (Docker PostgreSQL)
METRICS_DB_NAME=internal_metrics
METRICS_DB_USER=metrics_admin
METRICS_DB_PASSWORD=metrics_admin_change_me
METRICS_DB_PORT=5433
TZ=UTC

# Application
PORT=3000

# Internal metrics DB connector
PG_HOST=localhost
PG_PORT=5433
PG_USER=metrics_admin
PG_PASSWORD=metrics_admin_change_me
PG_DATABASE=internal_metrics

# Encryption key for database credentials (32 bytes hex = 64 chars)
# Generate new key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DB_CREDENTIALS_KEY=REPLACE_WITH_GENERATED_KEY
